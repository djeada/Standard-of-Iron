    {
      "route_id": "central_shrine_ring",
      "theme": "high-value middle without one-lane chokepoint",
      "primary_roads": ["southwest_to_central_west_ring", "northeast_to_central_east_ring", "central_north_arc", "central_south_arc"],
      "intended_choice": "Fight for the ruined shrine ridge and its surrounding clearings, but approach from multiple roads instead of one direct road over the hill.",
      "risk": "The center attracts both armies and is vulnerable to flanks from north and south arcs.",
      "reward": "Vision, safe rally point, and shorter rotations to both neutral barracks."
    },
    {
      "route_id": "north_lodge_control",
      "theme": "upper forest side objective",
      "primary_roads": ["southwest_to_north_lodge_outer", "northeast_to_north_lodge_inner", "north_lodge_to_center"],
      "intended_choice": "Capture the northern neutral barracks to gain archers and a protected route toward the enemy back road.",
      "risk": "The path is longer and passes through dense ambush woods.",
      "reward": "Neutral archer support and control over the northern forest loop."
    },
    {
      "route_id": "south_lodge_control",
      "theme": "lower forest side objective",
      "primary_roads": ["southwest_to_south_lodge_inner", "northeast_to_south_lodge_outer", "south_lodge_to_center"],
      "intended_choice": "Capture the southern neutral barracks to gain spearmen and control the lower ambush route.",
      "risk": "The route is slower for siege and has multiple forest pockets where cavalry can be trapped.",
      "reward": "Neutral spearmen, safer anti-cavalry screen, and access to the enemy's southern approach."
    },
    {
      "route_id": "outer_raid_loop",
      "theme": "long forest flank and backdoor pressure",
      "primary_roads": ["western_outer_forest_road", "northern_outer_road", "eastern_outer_forest_road", "southern_outer_road"],
      "intended_choice": "Avoid the center and use the long outer forest loop for raids, siege movement, or delayed attacks.",
      "risk": "Travel time is long and neutral camps can interrupt unsupported armies.",
      "reward": "Can bypass the central shrine and hit supply props or side entrances."
    },
    {
      "route_id": "ambush_cutpaths",
      "theme": "small tactical paths for infantry and scouts",
      "primary_roads": ["western_ambush_cutpath", "eastern_ambush_cutpath", "north_shadow_trail", "south_shadow_trail"],
      "intended_choice": "Use narrow forest tracks to hide archers, scouts, and small infantry groups.",
      "risk": "Not ideal for catapults or large formations.",
      "reward": "Surprise attacks onto roads, neutral barracks, or center ring."
    }
